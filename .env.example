# Django
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (dev: SQLite | prod: PostgreSQL)
DATABASE_ENGINE=sqlite
# For PostgreSQL (Docker):
# DATABASE_ENGINE=postgres
# DATABASE_NAME=matrimony_db
# DATABASE_USER=matrimony_user
# DATABASE_PASSWORD=secure_password
# DATABASE_HOST=postgres
# DATABASE_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (RS256: 15 min access, 30 days refresh; optional HTTP-only cookie)
# JWT_PRIVATE_KEY=path/to/private.pem
# JWT_PUBLIC_KEY=path/to/public.pem
JWT_REFRESH_COOKIE_NAME=refresh_token
JWT_REFRESH_COOKIE_SECURE=False

# OTP rate limit: max 5 requests per 10 minutes per phone/email
# (configured in settings; override via OTP_RATE_LIMIT_* if needed)

# SMS: console | twilio | msg91
SMS_BACKEND=console
# Twilio:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# MSG91:
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=MATRIM
# MSG91_OTP_TEMPLATE_ID=

# Email (OTP fallback / notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@matrimony.example.com

# AWS S3 / MinIO (optional; leave USE_S3=False for local MEDIA)
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=https://minio.example.com  # MinIO

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
