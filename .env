# Django
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (dev: SQLite | prod: MySQL)
DATABASE_ENGINE=sqlite
# For MySQL:
# DATABASE_ENGINE=mysql
# DATABASE_NAME=matrimony_db
# DATABASE_USER=matrimony_user
# DATABASE_PASSWORD=secure_password
# DATABASE_HOST=mysql
# DATABASE_PORT=3306

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (optional: use RS256 with keys, or leave empty for HS256). Lifetimes in minutes.
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=10
JWT_REFRESH_TOKEN_LIFETIME_MINUTES=30
# JWT_PRIVATE_KEY=path/to/private.pem
# JWT_PUBLIC_KEY=path/to/public.pem

# Email (optional for OTP fallback / notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@matrimony.example.com

# SMS (placeholder - integrate with provider)
SMS_BACKEND=console

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
